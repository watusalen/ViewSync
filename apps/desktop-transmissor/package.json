{
  "name": "view-sync-desktop",
  "private": true,
  "version": "1.0.4",
  "description": "ViewSync - Transmissor de Tela",
  "author": "Kellviny",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "cd ../viewer-web && npm run build && cd ../desktop-transmissor && tsc && vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "rebuild:native": "electron-rebuild -f -w mediasoup",
    "clean:native": "node -e \"require('fs').rmSync('node_modules/mediasoup/worker/out', { recursive: true, force: true })\" && npm run rebuild:native",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/fira-sans": "^5.2.7",
    "bufferutil": "^4.1.0",
    "depd": "^2.0.0",
    "express": "^4.19.2",
    "lucide-react": "^1.14.0",
    "mediasoup": "^3.19.22",
    "mediasoup-client": "^3.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "selfsigned": "^5.5.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3",
    "utf-8-validate": "^6.0.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/express": "^4.17.21",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "30.0.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.2.2",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.viewsync.studio",
    "productName": "ViewSync Studio",
    "electronVersion": "30.0.1",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/ico.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/ico.icns",
      "category": "public.app-category.education",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "This app needs screen capture to broadcast your screen.",
        "NSMicrophoneUsageDescription": "This app needs microphone access for audio streaming."
      }
    },
    "mas": {
      "target": [
        "mas"
      ],
      "category": "public.app-category.education",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "This app needs screen capture to broadcast your screen.",
        "NSMicrophoneUsageDescription": "This app needs microphone access for audio streaming."
      }
    },
    "asar": false,
    "files": [
      "dist",
      "dist-electron",
      "node_modules"
    ],
    "extraResources": [
      {
        "from": "../viewer-web/out",
        "to": "viewer",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
