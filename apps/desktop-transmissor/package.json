{
  "name": "view-sync-desktop",
  "private": true,
  "version": "1.0.4",
  "description": "ViewSync - Transmissor de Tela",
  "author": "Kellviny",
  "scripts": {
    "dev": "vite",
    "build": "cd ../viewer-web && npm run build && cd ../desktop-transmissor && tsc && vite build && electron-builder",
    "rebuild": "electron-rebuild -f -w mediasoup",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.19.2",
    "lucide-react": "^1.14.0",
    "mediasoup": "^3.19.22",
    "mediasoup-client": "^3.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "30.0.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.viewsync.studio",
    "productName": "ViewSync Studio",
    "electronVersion": "30.0.1",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/ico.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/ico.icns",
      "category": "public.app-category.education",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "asar": false,
    "files": [
      "dist",
      "dist-electron",
      "node_modules"
    ],
    "extraResources": [
      {
        "from": "../viewer-web/out",
        "to": "viewer",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
